{
  "name": "multilang-calendar",
  "version": "0.3.0",
  "description": "A framework-agnostic, fully internationalized calendar with built-in locale dictionaries (incl. Tamazight/Tifinagh), Gregorian, Hijri/Islamic, Persian, Hebrew and Amazigh (Berber) calendar systems, date selection, ranges and event markers.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://calendarmulti.netlify.app/",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/eyoussef/multilang-calendar.git"
  },
  "bugs": {
    "url": "https://github.com/eyoussef/multilang-calendar/issues"
  },
  "keywords": [
    "calendar",
    "i18n",
    "multilanguage",
    "intl",
    "hijri",
    "islamic",
    "tamazight",
    "tifinagh",
    "amazigh",
    "berber",
    "yennayer",
    "react",
    "vue",
    "web-component"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs"
    },
    "./style.css": "./dist/calendar.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.build.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "vue": ">=3.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^3.9.1",
    "vue": "^3.4.31"
  }
}
